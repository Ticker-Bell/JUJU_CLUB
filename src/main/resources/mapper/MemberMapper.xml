<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tickerbell.jujuclub.auth.mapper.MemberMapper">

    <select id="selectUserById" parameterType="string" resultType="com.tickerbell.jujuclub.auth.dto.MemberDTO">
        SELECT
            user_seq as userSeq,
            user_id as userId,
            user_pw as userPw,
            user_name as userName,
            user_level as userLevel,
            created_at as createdAt
        FROM USERS
        WHERE user_id = #{userId}
    </select>

    <update id="updateUser" parameterType="com.tickerbell.jujuclub.auth.dto.MemberDTO">
        UPDATE USERS
        <set>
            <if test="userName != null and userName != ''">
                user_name = #{userName},
            </if>
            <if test="userPw != null and userPw != ''">
                user_pw = #{userPw},
            </if>
        </set>
        WHERE user_id = #{userId}
    </update>

    <delete id="deleteUser">
        DELETE FROM USERS WHERE user_id = #{userId}
    </delete>

</mapper>