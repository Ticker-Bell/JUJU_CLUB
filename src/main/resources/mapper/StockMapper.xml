<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.tickerbell.jujuclub.invest.stockList.mapper.StockMapper">

    <!-- 종목 seq로 종목정보 전체 조회 -->
    <select id="findBySeq" parameterType="integer" resultType="com.tickerbell.jujuclub.invest.stockList.dto.StockDTO">
        SELECT *
        FROM STOCK_MASTER
        WHERE stock_seq = #{seq}
    </select>

    <!-- 유저 관심 종목 테이블과 조인해서 유저가 즐겨찾기한 종목들의 코드 조회 -->
    <select id="findStockCodeListFromUserWatchList" parameterType="integer" resultType="com.tickerbell.jujuclub.invest.stockList.dto.StockDTO">
        SELECT STOCK_MASTER.*
        FROM USER_WATCHLIST join STOCK_MASTER
        ON (USER_WATCHLIST.stock_seq = STOCK_MASTER.stock_seq)
        WHERE user_seq = #{userSeq}
    </select>

</mapper>