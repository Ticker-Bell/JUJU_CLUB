<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.tickerbell.jujuclub.auth.mapper.SignupMapper">

    <!-- user_name 중복 체크 -->
    <select id="existsByUserName" parameterType="string" resultType="int">
        SELECT COUNT(1)
        FROM USERS
        WHERE user_name = #{value}
    </select>

    <!-- user_id 중복 체크 -->
    <select id="existsByUserId" parameterType="string" resultType="int">
        SELECT COUNT(1)
        FROM USERS
        WHERE user_id = #{value}
    </select>

    <!-- 회원가입 -->
    <insert id="insertUser" parameterType="com.tickerbell.jujuclub.auth.dto.SignupDTO">
        INSERT INTO USERS (user_id, user_pw, user_name, user_level, created_at)
        VALUES (#{userId}, #{userPw}, #{userName}, null, NOW())
    </insert>

</mapper>