<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tickerbell.jujuclub.invest.mapper.UserAssetMapper">
    <!--보유 이용가능자금 조회-->
    <select id="selectCashBalance" parameterType="int" resultType="long">
        select cash_balance
        from user_account
        where user_seq = #{user_seq}
    </select>

</mapper>